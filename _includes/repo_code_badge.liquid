{%- if include.href -%}
<a href="{{ include.href }}" class="repo-code-badge"{% if include.aria_label %} aria-label="{{ include.aria_label }}"{% endif %}>
  <span class="repo-code-angle">&lt;</span><span class="repo-code-slash">/</span><span class="repo-code-angle">&gt;</span>
</a>
{%- else -%}
<span class="repo-code-badge"{% if include.aria_label %} aria-label="{{ include.aria_label }}"{% else %} aria-hidden="true"{% endif %}>
  <span class="repo-code-angle">&lt;</span><span class="repo-code-slash">/</span><span class="repo-code-angle">&gt;</span>
</span>
{%- endif -%}